import torch
import os
from transformers import (
    AutoModelForCausalLM,
    AutoTokenizer,
    BitsAndBytesConfig,
    TrainingArguments,
)
from peft import (
    LoraConfig,
    get_peft_model,
    prepare_model_for_kbit_training,
    TaskType,
)
from trl import SFTTrainer, SFTConfig
from datasets import load_dataset
import warnings
warnings.filterwarnings('ignore')
 
print(f"PyTorch version: {torch.__version__}")
print(f"CUDA available: {torch.cuda.is_available()}")
if torch.cuda.is_available():
    print(f"GPU: {torch.cuda.get_device_name(0)}")
    print(f"VRAM: {torch.cuda.get_device_properties(0).total_memory / 1e9:.1f} GB")
 


from huggingface_hub import login
 
HF_TOKEN = "your token here"  # paste your token here
login(token=HF_TOKEN)
print("Logged in to HuggingFace!")
 


dataset = load_dataset("spider", trust_remote_code=True)
 
print(f"Train samples: {len(dataset['train'])}")
print(f"Validation samples: {len(dataset['validation'])}")
print(f"\nSample entry:")
print(f"Question: {dataset['train'][0]['question']}")
print(f"SQL:      {dataset['train'][0]['query']}")
print(f"DB:       {dataset['train'][0]['db_id']}")
 


def format_prompt(example):
    """
    Convert Spider dataset into instruction format.
    The model learns: given a question + schema hint → generate SQL.
    """
    prompt = f"""### Instruction:
Convert the following natural language question to a SQL query.
 
### Question:
{example['question']}
 
### Database:
{example['db_id']}
 
### SQL Query:
{example['query']}"""
    return {"text": prompt}
 
 
# Apply formatting
train_data = dataset["train"].map(format_prompt, remove_columns=dataset["train"].column_names)
val_data   = dataset["validation"].map(format_prompt, remove_columns=dataset["validation"].column_names)
 
print(f"Formatted train: {len(train_data)} samples")
print(f"\nExample formatted prompt:")
print(train_data[0]["text"])
 


MODEL_NAME = "TinyLlama/TinyLlama-1.1B-Chat-v1.0"
 
# 4-bit quantization config — lets us fit model in 15GB VRAM
bnb_config = BitsAndBytesConfig(
    load_in_4bit=True,
    bnb_4bit_quant_type="nf4",           # NormalFloat4 — best for LLMs
    bnb_4bit_compute_dtype=torch.float16,
    bnb_4bit_use_double_quant=True,       # saves extra memory
)
 
print(f"Loading {MODEL_NAME}...")
model = AutoModelForCausalLM.from_pretrained(
    MODEL_NAME,
    quantization_config=bnb_config,
    device_map="auto",
    trust_remote_code=True,
)
tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME, trust_remote_code=True)
tokenizer.pad_token = tokenizer.eos_token
tokenizer.padding_side = "right"
 
print(f"Model loaded!")
print(f"Parameters: {sum(p.numel() for p in model.parameters()) / 1e9:.2f}B")
 


# Prepare model for LoRA training
model = prepare_model_for_kbit_training(model)
 
# LoRA configuration
# r = rank (lower = fewer params = faster, higher = more expressive)
# alpha = scaling factor (usually 2x rank)
# target_modules = which layers to add LoRA to
lora_config = LoraConfig(
    r=8,                          # rank — 8 is good balance for 15GB
    lora_alpha=16,                # scaling
    lora_dropout=0.05,
    bias="none",
    task_type=TaskType.CAUSAL_LM,
    target_modules=[              # attention layers
        "q_proj", "k_proj",
        "v_proj", "o_proj",
        "gate_proj", "up_proj", "down_proj",
    ],
)
 
model = get_peft_model(model, lora_config)
 
# Show how many parameters we're actually training
trainable = sum(p.numel() for p in model.parameters() if p.requires_grad)
total     = sum(p.numel() for p in model.parameters())
print(f"Trainable parameters: {trainable:,} ({100 * trainable / total:.2f}% of total)")
print("This is the magic of LoRA — training <1% of parameters!")
 


OUTPUT_DIR = "./text2sql-tinyllama-lora"

training_args = SFTConfig(
    output_dir=OUTPUT_DIR,
    num_train_epochs=3,
    per_device_train_batch_size=4,
    per_device_eval_batch_size=4,
    gradient_accumulation_steps=4,
    learning_rate=2e-4,
    lr_scheduler_type="cosine",
    warmup_ratio=0.05,
    fp16=False,
    bf16=False,
    logging_steps=50,
    eval_steps=200,
    save_steps=200,
    eval_strategy="steps",
    save_strategy="steps",
    load_best_model_at_end=True,
    report_to="none",
    
)

print("Training config ready!")
print(f"Effective batch size: {training_args.per_device_train_batch_size * training_args.gradient_accumulation_steps}")


trainer = SFTTrainer(
    model=model,
    train_dataset=train_data,
    eval_dataset=val_data,
    args=training_args,
    formatting_func=lambda x: x["text"],
)

print("Starting fine-tuning...")
print("This will take ~20-30 minutes on Kaggle T4 GPU")
print("-" * 50)

trainer.train()

print("\nTraining complete!")


trainer.model.save_pretrained(OUTPUT_DIR)
tokenizer.save_pretrained(OUTPUT_DIR)
print(f"Model saved to {OUTPUT_DIR}")
 


from peft import PeftModel
from transformers import pipeline
 
def generate_sql(question, db_name="database", max_new_tokens=128):
    """Generate SQL from a natural language question."""
    prompt = f"""### Instruction:
Convert the following natural language question to a SQL query.
 
### Question:
{question}
 
### Database:
{db_name}
 
### SQL Query:
"""
    inputs = tokenizer(prompt, return_tensors="pt").to(model.device)
    with torch.no_grad():
        outputs = model.generate(
            **inputs,
            max_new_tokens=max_new_tokens,
            temperature=0.1,        # low temp = more deterministic
            do_sample=True,
            pad_token_id=tokenizer.eos_token_id,
        )
    generated = tokenizer.decode(outputs[0], skip_special_tokens=True)
    # Extract just the SQL part after "### SQL Query:"
    if "### SQL Query:" in generated:
        sql = generated.split("### SQL Query:")[-1].strip()
        # Stop at next ### if present
        if "###" in sql:
            sql = sql.split("###")[0].strip()
        return sql
    return generated
 
# Test on sample questions
test_questions = [
    ("How many students are enrolled in each course?", "university"),
    ("Show me all products with price greater than 100", "store"),
    ("Find the top 5 customers by total order value", "ecommerce"),
    ("What is the average salary by department?", "hr"),
    ("List all orders placed in 2024", "orders"),
]
 
print("=" * 60)
print("MODEL INFERENCE — Text to SQL")
print("=" * 60)
for question, db in test_questions:
    sql = generate_sql(question, db)
    print(f"\nQuestion: {question}")
    print(f"Database: {db}")
    print(f"SQL:      {sql}")
    print("-" * 40)


from evaluate import load
import random
 
bleu_metric = load("sacrebleu")
 
# Sample 100 examples for evaluation (full eval takes long)
eval_samples = val_data.select(range(min(100, len(val_data))))
 
predictions = []
references  = []
 
print("Evaluating on 100 validation samples...")
for i, sample in enumerate(eval_samples):
    text = sample["text"]
    # Extract question and reference SQL from formatted prompt
    parts = text.split("### SQL Query:")
    if len(parts) < 2:
        continue
    question_part = parts[0]
    reference_sql = parts[1].strip()
 
    # Extract question
    q_parts = question_part.split("### Question:")
    if len(q_parts) < 2:
        continue
    question = q_parts[1].split("### Database:")[0].strip()
    db = q_parts[1].split("### Database:")[-1].strip() if "### Database:" in q_parts[1] else "database"
 
    pred_sql = generate_sql(question, db)
    predictions.append(pred_sql)
    references.append([reference_sql])
 
    if (i + 1) % 20 == 0:
        print(f"  Evaluated {i+1}/100...")
 
bleu = bleu_metric.compute(predictions=predictions, references=references)
print(f"\nBLEU Score: {bleu['score']:.2f}")
print("(Higher is better. Fine-tuned model should score significantly higher than base model.)")
 


